{
  "name": "ne-wb-github.io",
  "version": "0.0.1",
  "bugs": {
    "url": "https://github.com/314oner/ne-wb-github.io/issues"
  },
  "license": "MIT",
  "author": "Aleksandr Gverdtsiteli",
  "type": "module",
  "scripts": {
    "dev": "dotenvx run -f .env.example -- vite --config vite.config.ts",
    "dev:clean": "rm -rf node_modules/.vite_cache && yarn dev",
    "frontend:build": "vite build --config vite.config.prod.ts --emptyOutDir",
    "frontend:build:dev": "vite build --config vite.config.ts --emptyOutDir",
    "preview": "dotenvx run -f .env.production -- vite preview --port 5001",
    "analyze": "yarn build && source-map-explorer dist/assets/*.js --json result.json",
    "typecheck": "tsc --noEmit",
    "preview:dev": "dotenvx run -f .env.example -- vite preview --port 5001",
    "css": "tailwindcss -c ./tailwind.config.js -i ./src/index.css -o ./src/cypress.css -w",
    "dotenvx": "dotenvx",
    "env:decrypt": "dotenvx decrypt -f .env.production",
    "env:encrypt": "dotenvx encrypt -f .env.production"
  },
  "dependencies": {
    "@314oner_npm/universal-components-library": "3.4.5",
    "@faker-js/faker": "^10.4.0",
    "@reduxjs/toolkit": "2.5.0",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "^4.12.0",
    "react-redux": "9.2.0",
    "react-router-dom": "6.28.0",
    "react-toastify": "^11.0.5",
    "redux-persist": "^6.0.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "workbox-window": "^7.1.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.32.0",
    "@types/node": "^25.2.3",
    "@types/prop-types": "^15.7.13",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/react-lazy-load-image-component": "^1",
    "@types/react-lazyload": "^3.2.3",
    "@types/redux-logger": "^3.0.13",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "autoprefixer": "^10.4.16",
    "axe-core": "^4.9.1",
    "cypress": "^13.12.0",
    "cypress-axe": "^1.5.0",
    "postcss": "^8.4.31",
    "redux-injectors": "^2.1.0",
    "redux-logger": "3.0.6",
    "rollup-plugin-analyzer": "^4.0.0",
    "rollup-plugin-visualizer": "^7.0.0",
    "sharp": "^0.35.1",
    "source-map-explorer": "^2.5.3",
    "svgo": "^4.0.1",
    "tailwind-scrollbar": "^3.0.5",
    "tailwindcss": "^3.3.5",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.2.2",
    "vite": "^5.0.0",
    "vite-bundle-stats-metrics": "^1.0.11",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-image-optimizer": "^1.1.8",
    "vite-plugin-inspect": "^12.0.0-beta.1",
    "vite-plugin-pwa": "^1.0.0",
    "workbox-precaching": "^7.3.0"
  },
  "resolutions": {
    "@314oner_npm/universal-components-library/react": "18.2.0",
    "@314oner_npm/universal-components-library/react-dom": "18.2.0"
  },
  "packageManager": "yarn@4.12.0"
}
